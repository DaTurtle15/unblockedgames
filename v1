function pong(canvas){const ctx=canvas.getContext('2d');let W=canvas.width,H=canvas.height;const PH=72,PW=12;let p1={y:H/2-PH/2,s:0},p2={y:H/2-PH/2,s:0};let bx=W/2,by=H/2,bvx=4.5*(Math.random()>.5?1:-1),bvy=3*(Math.random()>.5?1:-1);let alive=true,raf;const ks={};const kh=e=>ks[e.key]=e.type==='keydown';window.addEventListener('keydown',kh);window.addEventListener('keyup',kh);function draw(){ctx.fillStyle='#1a1917';ctx.fillRect(0,0,W,H);ctx.setLineDash([7,7]);ctx.strokeStyle='#2a2a28';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(W/2,0);ctx.lineTo(W/2,H);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle='#fff';ctx.beginPath();ctx.roundRect(14,p1.y,PW,PH,4);ctx.fill();ctx.beginPath();ctx.roundRect(W-14-PW,p2.y,PW,PH,4);ctx.fill();ctx.beginPath();ctx.arc(bx,by,8,0,Math.PI*2);ctx.fill();ctx.font='bold 30px Syne,sans-serif';ctx.textAlign='center';ctx.fillText(p1.s,W/2-44,46);ctx.fillText(p2.s,W/2+44,46);ctx.textAlign='left';}let last=0;function loop(ts){if(!alive)return;raf=requestAnimationFrame(loop);if(ts-last<16)return;last=ts;const SP=6;if(ks['w']||ks['W'])p1.y=Math.max(0,p1.y-SP);if(ks['s']||ks['S'])p1.y=Math.min(H-PH,p1.y+SP);if(ks['ArrowUp'])p2.y=Math.max(0,p2.y-SP);if(ks['ArrowDown'])p2.y=Math.min(H-PH,p2.y+SP);bx+=bvx;by+=bvy;if(by<8||by>H-8)bvy=-bvy;if(bx<14+PW+8&&by>p1.y&&by<p1.y+PH){bvx=Math.abs(bvx)*1.04;bvy+=((by-(p1.y+PH/2))/(PH/2))*2;}if(bx>W-14-PW-8&&by>p2.y&&by<p2.y+PH){bvx=-Math.abs(bvx)*1.04;bvy+=((by-(p2.y+PH/2))/(PH/2))*2;}bvx=Math.max(-12,Math.min(12,bvx));if(bx<0){p2.s++;bx=W/2;by=H/2;bvx=4.5*(Math.random()>.5?1:-1);bvy=3*(Math.random()>.5?1:-1);}if(bx>W){p1.s++;bx=W/2;by=H/2;bvx=4.5*(Math.random()>.5?1:-1);bvy=3*(Math.random()>.5?1:-1);}draw();}raf=requestAnimationFrame(loop);return()=>{alive=false;cancelAnimationFrame(raf);window.removeEventListener('keydown',kh);window.removeEventListener('keyup',kh);};}

function game2048(canvas){const ctx=canvas.getContext('2d');let W=canvas.width,H=canvas.height;const N=4,PAD=10;const SZ=Math.min(Math.floor((Math.min(W,H)-PAD*(N+1))/N),Math.floor((H-80-PAD*(N+1))/N));const GW=SZ*N+PAD*(N+1),GH=SZ*N+PAD*(N+1);const GX=Math.floor((W-GW)/2),GY=60;let board,score,best=0,alive=true;const COLORS={0:'#ccc0b3',2:'#eee4da',4:'#ede0c8',8:'#f2b179',16:'#f59563',32:'#f67c5f',64:'#f65e3b',128:'#edcf72',256:'#edcc61',512:'#edc850',1024:'#edc53f',2048:'#edc22e'};const TCOL={0:'#776e65',2:'#776e65',4:'#776e65',8:'#f9f6f2',16:'#f9f6f2',32:'#f9f6f2',64:'#f9f6f2',128:'#f9f6f2',256:'#f9f6f2',512:'#f9f6f2',1024:'#f9f6f2',2048:'#f9f6f2'};function init(){board=Array.from({length:N},()=>Array(N).fill(0));score=0;add();add();}function add(){const emp=[];for(let r=0;r<N;r++)for(let c=0;c<N;c++)if(!board[r][c])emp.push([r,c]);if(!emp.length)return;const[r,c]=emp[Math.floor(Math.random()*emp.length)];board[r][c]=Math.random()<.9?2:4;}function move(dir){const rotate=m=>m[0].map((_,i)=>m.map(r=>r[i]).reverse());let b=board.map(r=>[...r]);let times=dir==='left'?0:dir==='up'?1:dir==='right'?2:3;let moved=false;for(let i=0;i<times;i++)b=rotate(b);for(let r=0;r<N;r++){let row=b[r].filter(v=>v);for(let i=0;i<row.length-1;i++){if(row[i]===row[i+1]){score+=row[i]*2;row[i]*=2;row.splice(i+1,1);}}const nrow=[...row,...Array(N-row.length).fill(0)];if(nrow.join()!==b[r].join())moved=true;b[r]=nrow;}for(let i=0;i<(4-times)%4;i++)b=rotate(b);if(moved){board=b;add();}if(score>best)best=score;}function draw(){ctx.fillStyle='#f8f7f4';ctx.fillRect(0,0,W,H);ctx.fillStyle='#888';ctx.font='13px Syne,sans-serif';ctx.fillText('Score: '+score,10,22);ctx.textAlign='right';ctx.fillText('Best: '+best,W-10,22);ctx.textAlign='left';ctx.fillStyle='#ccc0b3';ctx.beginPath();ctx.roundRect(GX,GY,GW,GH,10);ctx.fill();for(let r=0;r<N;r++)for(let c=0;c<N;c++){const v=board[r][c],x=GX+PAD+c*(SZ+PAD),y=GY+PAD+r*(SZ+PAD);ctx.fillStyle=COLORS[Math.min(v,2048)]||'#3c3a32';ctx.beginPath();ctx.roundRect(x,y,SZ,SZ,6);ctx.fill();if(v){ctx.fillStyle=TCOL[Math.min(v,2048)]||'#f9f6f2';const fs=v<100?SZ*.4:v<1000?SZ*.32:SZ*.26;ctx.font=`bold ${fs}px Syne,sans-serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(v,x+SZ/2,y+SZ/2);ctx.textAlign='left';ctx.textBaseline='alphabetic';}}if(board.flat().includes(2048)){over('You Win! 🎉');return;}const hm=board.flat().some(v=>!v)||board.some((r,ri)=>r.some((v,ci)=>(ci<N-1&&v===r[ci+1])||(ri<N-1&&v===board[ri+1][ci])));if(!hm)over('Game Over');}function over(msg){ctx.fillStyle='rgba(248,247,244,.88)';ctx.fillRect(0,0,W,H);ctx.fillStyle='#1a1917';ctx.font='bold 24px Syne,sans-serif';ctx.textAlign='center';ctx.fillText(msg,W/2,H/2-8);ctx.font='13px Syne,sans-serif';ctx.fillStyle='#888';ctx.fillText('Click to restart',W/2,H/2+20);ctx.textAlign='left';alive=false;}const kh=e=>{if(!alive)return;const m={ArrowLeft:'left',ArrowRight:'right',ArrowUp:'up',ArrowDown:'down'};if(m[e.key]){e.preventDefault();move(m[e.key]);draw();}};window.addEventListener('keydown',kh);canvas.addEventListener('click',()=>{if(!alive){init();alive=true;draw();}});init();draw();return()=>{window.removeEventListener('keydown',kh);};}

function dino(canvas){const ctx=canvas.getContext('2d');let W=canvas.width,H=canvas.height;const GY=H-40;let dn={x:60,y:GY,vy:0,h:36,w:22,duck:false,lp:0};let obs=[],score=0,speed=4,alive=true,started=false,raf,frame=0;function jump(){if(!started)started=true;if(dn.y>=GY)dn.vy=-11;}function draw(){ctx.fillStyle='#f8f7f4';ctx.fillRect(0,0,W,H);ctx.fillStyle='#1a1917';ctx.fillRect(0,GY+dn.h,W,2);const dh=dn.duck?20:dn.h;const dy=GY+(dn.h-dh);ctx.fillStyle='#1a1917';ctx.beginPath();ctx.roundRect(dn.x,dy,dn.w,dh,4);ctx.fill();ctx.beginPath();ctx.roundRect(dn.x+dn.w-4,dy-16,20,16,4);ctx.fill();ctx.fillStyle='#f8f7f4';ctx.beginPath();ctx.arc(dn.x+dn.w+12,dy-10,3,0,Math.PI*2);ctx.fill();if(!dn.duck&&dn.y>=GY){const lv=Math.sin(dn.lp);ctx.fillStyle='#1a1917';ctx.fillRect(dn.x+4,GY+dh,6,6+lv*4);ctx.fillRect(dn.x+12,GY+dh,6,6-lv*4);}obs.forEach(o=>{ctx.fillStyle='#1a1917';ctx.beginPath();ctx.roundRect(o.x,GY+dn.h-o.h,o.w,o.h,3);ctx.fill();for(let i=0;i<3;i++){ctx.beginPath();ctx.moveTo(o.x+4+i*8,GY+dn.h-o.h);ctx.lineTo(o.x+8+i*8,GY+dn.h-o.h-10);ctx.lineTo(o.x+12+i*8,GY+dn.h-o.h);ctx.fillStyle='#333';ctx.fill();}});ctx.fillStyle='#aaa';ctx.font='13px Syne,sans-serif';ctx.fillText('Score: '+Math.floor(score),10,22);if(!started){ctx.fillStyle='rgba(26,25,23,.5)';ctx.font='14px Syne,sans-serif';ctx.textAlign='center';ctx.fillText('Space or ↑ to start',W/2,H/2+20);ctx.textAlign='left';}}let last=0;function loop(ts){if(!alive)return;raf=requestAnimationFrame(loop);if(ts-last<16)return;last=ts;frame++;if(started){dn.vy+=.55;dn.y=Math.min(GY,dn.y+dn.vy);if(dn.y>=GY)dn.vy=0;dn.lp+=.25;score+=.1;speed=4+Math.floor(score/50)*.5;if(frame%Math.max(55,90-Math.floor(score/20))===0){obs.push({x:W,h:28+Math.floor(Math.random()*18),w:26+Math.floor(Math.random()*10)});}obs.forEach(o=>o.x-=speed);obs=obs.filter(o=>o.x>-60);const dh=dn.duck?18:dn.h;const dy=GY+(dn.h-dh);for(const o of obs){if(dn.x+dn.w-4>o.x+2&&dn.x+4<o.x+o.w-2&&dy+dh-4>GY+dn.h-o.h){alive=false;ctx.fillStyle='rgba(248,247,244,.88)';ctx.fillRect(0,0,W,H);ctx.fillStyle='#1a1917';ctx.font='bold 24px Syne,sans-serif';ctx.textAlign='center';ctx.fillText('Score: '+Math.floor(score),W/2,H/2-8);ctx.font='13px Syne,sans-serif';ctx.fillStyle='#888';ctx.fillText('Click to restart',W/2,H/2+20);ctx.textAlign='left';return;}}}draw();}function restart(){dn={x:60,y:GY,vy:0,h:36,w:22,duck:false,lp:0};obs=[];score=0;speed=4;alive=true;started=true;frame=0;raf=requestAnimationFrame(loop);}canvas.addEventListener('click',()=>{if(!alive)restart();else jump();});const kh=e=>{if(e.code==='Space'||e.key==='ArrowUp'){e.preventDefault();if(!alive)restart();else jump();}if(e.key==='ArrowDown'){e.preventDefault();dn.duck=true;}};const ku=e=>{if(e.key==='ArrowDown')dn.duck=false;};window.addEventListener('keydown',kh);window.addEventListener('keyup',ku);raf=requestAnimationFrame(loop);return()=>{alive=false;cancelAnimationFrame(raf);window.removeEventListener('keydown',kh);window.removeEventListener('keyup',ku);};}

