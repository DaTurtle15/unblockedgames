// ── Thumbnails ──
function drawThumb(id, canvas) {
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.fillStyle = '#efefec'; ctx.fillRect(0,0,W,H);
  const d = {
    snake:()=>{for(let i=0;i<5;i++){ctx.fillStyle=i===0?'#1a1917':`rgba(26,25,23,${.9-i*.15})`;ctx.beginPath();ctx.roundRect(28+i*22,H/2-9,18,18,4);ctx.fill();}ctx.fillStyle='#e55';ctx.beginPath();ctx.arc(18,H/2,6,0,Math.PI*2);ctx.fill();},
    breakout:()=>{const cs=['#1a1917','#444','#777','#aaa'];for(let r=0;r<4;r++)for(let c=0;c<7;c++){ctx.fillStyle=cs[r];ctx.beginPath();ctx.roundRect(8+c*22,6+r*13,20,10,2);ctx.fill();}ctx.fillStyle='#1a1917';ctx.beginPath();ctx.roundRect(52,H-16,56,8,4);ctx.fill();ctx.beginPath();ctx.arc(80,H-24,6,0,Math.PI*2);ctx.fillStyle='#555';ctx.fill();},
    tetris:()=>{[[0,3,'#1a1917'],[0,4,'#1a1917'],[1,3,'#444'],[1,4,'#444'],[2,2,'#666'],[2,3,'#666'],[3,2,'#888'],[3,3,'#888']].forEach(([r,c,col])=>{ctx.fillStyle=col;ctx.fillRect(18+c*18,4+r*18,16,16);});},
    flappy:()=>{ctx.fillStyle='#1a1917';for(let i=0;i<3;i++){ctx.fillRect(35+i*55,0,24,28+i*6);ctx.fillRect(35+i*55,H-(22+i*8),24,22+i*8);}ctx.save();ctx.translate(24,H/2);ctx.fillStyle='#f5a623';ctx.beginPath();ctx.ellipse(0,0,13,9,0,0,Math.PI*2);ctx.fill();ctx.fillStyle='#1a1917';ctx.beginPath();ctx.arc(7,-2,4,0,Math.PI*2);ctx.fill();ctx.restore();},
    asteroids:()=>{ctx.strokeStyle='#1a1917';ctx.lineWidth=2;[[55,38,22],[115,60,15],[42,65,11],[138,28,13]].forEach(([x,y,r])=>{ctx.beginPath();for(let i=0;i<8;i++){const a=i*Math.PI*2/8,rv=r+(i%2?-4:4);i===0?ctx.moveTo(x+Math.cos(a)*rv,y+Math.sin(a)*rv):ctx.lineTo(x+Math.cos(a)*rv,y+Math.sin(a)*rv);}ctx.closePath();ctx.stroke();});ctx.beginPath();ctx.moveTo(80,H-10);ctx.lineTo(74,H-2);ctx.lineTo(86,H-2);ctx.closePath();ctx.stroke();},
    minesweeper:()=>{for(let r=0;r<6;r++)for(let c=0;c<8;c++){ctx.fillStyle=(r+c)%2===0?'#ddd':'#ccc';ctx.fillRect(8+c*20,4+r*13,18,11);}},
    pong:()=>{ctx.fillStyle='#1a1917';ctx.fillRect(0,0,W,H);ctx.fillStyle='#fff';ctx.beginPath();ctx.roundRect(8,H/2-22,10,44,4);ctx.fill();ctx.beginPath();ctx.roundRect(W-18,H/2-18,10,36,4);ctx.fill();ctx.beginPath();ctx.setLineDash([5,5]);ctx.moveTo(W/2,0);ctx.lineTo(W/2,H);ctx.strokeStyle='#333';ctx.stroke();ctx.setLineDash([]);ctx.beginPath();ctx.arc(W/2+18,H/2,7,0,Math.PI*2);ctx.fillStyle='#fff';ctx.fill();},
    '2048':()=>{const d=[['2','#eee4da'],['4','#ede0c8'],['8','#f2b179'],['16','#f59563'],['32','#f67c5f'],['64','#f65e3b'],['128','#edcf72'],['256','#edcc61'],['512','#edc850'],['1024','#edc53f'],['2','#eee4da'],['4','#ede0c8'],['8','#f2b179'],['16','#f59563'],['32','#f67c5f'],['64','#f65e3b']];for(let i=0;i<16;i++){const r=Math.floor(i/4),c=i%4;ctx.fillStyle=d[i][1];ctx.beginPath();ctx.roundRect(4+c*39,4+r*20,36,18,3);ctx.fill();ctx.fillStyle='#776e65';ctx.font='bold 8px sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(d[i][0],4+c*39+18,4+r*20+9);}ctx.textAlign='left';ctx.textBaseline='alphabetic';},
    dino:()=>{ctx.fillStyle='#1a1917';ctx.fillRect(0,H-10,W,2);ctx.fillRect(32,H-30,15,20);ctx.fillRect(32,H-38,20,10);ctx.fillRect(50,H-38,6,4);for(let i=0;i<3;i++)ctx.fillRect(75+i*38,H-22-(i===1?6:0),9,22+(i===1?6:0));},
  };
  if(d[id])d[id]();
}

// ── Render grid ──
function renderGrid(filter='all', search='') {
  const grid = document.getElementById('gameGrid');
  grid.innerHTML = '';
  const q = search.trim().toLowerCase();
  const filtered = GAMES.filter(g => {
    const matchFilter = filter === 'all' || g.tag === filter;
    const matchSearch = !q || g.name.toLowerCase().includes(q) || g.tag.includes(q);
    return matchFilter && matchSearch;
  });

  document.getElementById('countBadge').textContent = filtered.length + ' games';

  if(!filtered.length) {
    grid.innerHTML = '<div class="no-results">no games found — try a different search</div>';
    return;
  }

  let adInserted = false;
  filtered.forEach((game, idx) => {
    if(idx === 12 && !adInserted) {
      adInserted = true;
      const ad = document.createElement('div');
      ad.className = 'ad-mid-feed';
      ad.innerHTML = '<div class="ad-slot-mid">728 × 90 — in-feed ad</div>';
      grid.appendChild(ad);
    }
    const card = document.createElement('div');
    card.className = 'game-card';
    const isReal = game.type === 'iframe';
    card.innerHTML = `
      <div class="game-thumb">
        ${isReal
          ? `<img src="${game.thumb}" alt="${game.name}" loading="lazy" onerror="this.style.opacity=0">`
          : `<canvas width="200" height="112" id="thumb-${game.id}"></canvas>`
        }
        <div class="play-overlay"><div class="play-btn">▶</div></div>
      </div>
      <div class="game-info">
        <h3>${game.name}</h3>
        <div class="game-meta">
          <span class="tag">${game.tag}</span>
          ${game.hot ? '<span class="tag badge-hot">🔥 hot</span>' : ''}
          ${isReal ? '<span class="tag badge-real">live</span>' : ''}
        </div>
      </div>`;
    card.addEventListener('click', () => openGame(game));
    grid.appendChild(card);
    if(!isReal) requestAnimationFrame(() => {
      const c = document.getElementById('thumb-'+game.id);
      if(c) drawThumb(game.id, c);
    });
  });
}

// ── Filter + search ──
let activeFilter = 'all';
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    activeFilter = btn.dataset.filter;
    renderGrid(activeFilter, document.getElementById('searchInput').value);
  });
});
document.getElementById('searchInput').addEventListener('input', e => {
  renderGrid(activeFilter, e.target.value);
});

// ── Modal ──
let activeCleanup = null;

function openGame(game) {
  const backdrop = document.getElementById('modalBackdrop');
  const area = document.getElementById('modalGameArea');
  document.getElementById('modalTitle').textContent = game.name;
  document.getElementById('modalHint').textContent = game.hint;
  document.getElementById('modalSource').textContent = game.type === 'iframe' ? '🌐 live game' : '🎮 built-in';
  area.innerHTML = '';
  backdrop.classList.add('open');
  document.body.style.overflow = 'hidden';

  if(game.type === 'iframe') {
    const loading = document.createElement('div');
    loading.style.cssText = 'position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#111;color:#555;font-family:DM Mono,monospace;font-size:.78rem;letter-spacing:.05em;flex-direction:column;gap:14px;';
    loading.innerHTML = '<div style="width:30px;height:30px;border:2px solid #2a2a2a;border-top-color:#666;border-radius:50%;animation:spin .7s linear infinite"></div><span>Loading ' + game.name + '...</span>';
    area.appendChild(loading);
    const iframe = document.createElement('iframe');
    iframe.src = game.url;
    iframe.allow = 'fullscreen; autoplay; gamepad';
    iframe.allowFullscreen = true;
    iframe.style.cssText = 'display:none;position:absolute;top:0;left:0;width:100%;height:100%;border:none;background:#000;';
    iframe.onload = () => { loading.style.display='none'; iframe.style.display='block'; };
    area.appendChild(iframe);
    activeCleanup = () => { iframe.src='about:blank'; };
    document.getElementById('modalFullscreen').onclick = () => { if(iframe.requestFullscreen) iframe.requestFullscreen(); };
  } else {
    const canvas = document.createElement('canvas');
    canvas.style.cssText = 'display:block;width:100%;height:100%;position:absolute;top:0;left:0;background:#f8f7f4;';
    area.appendChild(canvas);
