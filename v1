function minesweeper(canvas){const ctx=canvas.getContext('2d');let W=canvas.width,H=canvas.height;const COLS=16,ROWS=12,MINES=28;const SZ=Math.min(Math.floor(W/COLS),Math.floor((H-36)/ROWS));const OX=Math.floor((W-COLS*SZ)/2),OY=32;let grid,rev,flagged,over=false,won=false,first=true,fc=0;function init(){grid=Array.from({length:ROWS},()=>Array(COLS).fill(0));rev=Array.from({length:ROWS},()=>Array(COLS).fill(false));flagged=Array.from({length:ROWS},()=>Array(COLS).fill(false));over=false;won=false;first=true;fc=0;draw();}function placeMines(er,ec){let p=0;while(p<MINES){const r=Math.floor(Math.random()*ROWS),c=Math.floor(Math.random()*COLS);if(Math.abs(r-er)<=1&&Math.abs(c-ec)<=1)continue;if(grid[r][c]===-1)continue;grid[r][c]=-1;p++;}for(let r=0;r<ROWS;r++)for(let c=0;c<COLS;c++){if(grid[r][c]===-1)continue;let n=0;for(let dr=-1;dr<=1;dr++)for(let dc=-1;dc<=1;dc++){const nr=r+dr,nc=c+dc;if(nr>=0&&nr<ROWS&&nc>=0&&nc<COLS&&grid[nr][nc]===-1)n++;}grid[r][c]=n;}}function reveal(r,c){if(r<0||r>=ROWS||c<0||c>=COLS||rev[r][c]||flagged[r][c])return;rev[r][c]=true;if(grid[r][c]===0)for(let dr=-1;dr<=1;dr++)for(let dc=-1;dc<=1;dc++)reveal(r+dr,c+dc);}const NC=['','#1a1917','#0a6','#e55','#55e','#e90','#0cc','#333','#888'];function draw(){ctx.fillStyle='#f8f7f4';ctx.fillRect(0,0,W,H);ctx.fillStyle='#aaa';ctx.font='13px Syne,sans-serif';ctx.fillText('💣 '+(MINES-fc),10,22);if(won){ctx.fillStyle='#2a2';ctx.fillText('You Win! 🎉',W/2-40,22);}if(over){ctx.fillStyle='#e55';ctx.fillText('BOOM! 💥',W/2-36,22);}for(let r=0;r<ROWS;r++)for(let c=0;c<COLS;c++){const x=OX+c*SZ,y=OY+r*SZ;if(rev[r][c]){ctx.fillStyle='#e8e7e3';ctx.fillRect(x+.5,y+.5,SZ-1,SZ-1);if(grid[r][c]===-1){ctx.fillStyle='#e55';ctx.fillRect(x+.5,y+.5,SZ-1,SZ-1);ctx.font=`${SZ*.6}px sans-serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('💣',x+SZ/2,y+SZ/2);}else if(grid[r][c]>0){ctx.fillStyle=NC[grid[r][c]];ctx.font=`bold ${SZ*.55}px Syne,sans-serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fi